#pragma once

#include <sys/time.h>
#include "dfatool_host_dpu.ah"

aspect DfatoolHostTiming : public DfatoolHostDPUTiming {
	unsigned long n_elements;
	unsigned int element_size;

	virtual int getKernel() { return kernel; }

	virtual void printKernelArgs() {
		printf("n_elements=%lu", n_elements);
	}

	DfatoolHostTiming() {
		element_size = sizeof(T);
	}

	advice call("% input_params(...)") : after() {
		Params* p = tjp->result();
		n_elements = p->input_size;
		printf("[>>] SCAN-SSA | n_dpus=%u n_ranks=%u n_elements=%lu\n", NR_DPUS, NR_RANKS, n_elements);
	}

	advice call("% scan_host(...)") : after() {
		printf("[--] SCAN-SSA | n_dpus=%u n_ranks=%u n_elements=%lu\n", n_dpus, NR_RANKS, n_elements);
	}

	advice execution("% main(...)") : after() {
		printf("[<<] SCAN-SSA | n_dpus=%u n_ranks=%u n_elements=%lu\n", NR_DPUS, NR_RANKS, n_elements);
	}
};
